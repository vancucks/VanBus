{
  "expo": {
    "name": "VanBus",
    "slug": "VanBus",
    "version": "1.2.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4C00FF"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.vancucks.VanBus",
      "versionCode": 6
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ed62eb37-091a-467d-8289-812c4f400a67"
      }
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#4C00FF"
        }
      ]
    ]
  }
}
